<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include layout="@layout/header2"/>

            <androidx.core.widget.NestedScrollView
                android:layout_marginBottom="80dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/bt_addcart">

                <LinearLayout
                    android:layout_marginBottom="90dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dp"
                    android:layout_marginRight="3dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/term"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/term" />

                                <TextView
                                    android:fontFamily="@font/custom_font"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Term &amp; Condition"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/privacy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/privacy" />

                                <TextView
                                    android:fontFamily="@font/custom_font"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Privacy Policy"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/returnp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/refund" />

                                <TextView
                                    android:fontFamily="@font/custom_font"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Return Policy"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/acc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/userco" />

                                <TextView
                                    android:fontFamily="@font/custom_font"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Profile"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/rate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/star" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:fontFamily="@font/custom_font"
                                    android:text="Rate Us"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/share"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/share" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:fontFamily="@font/custom_font"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Share App"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/about"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/about" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="About us"
                                    android:fontFamily="@font/custom_font"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/contact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/contact" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Contact us"
                                    android:fontFamily="@font/custom_font"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>


                    <LinearLayout
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/developer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:padding="10dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/developer" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Developer"
                                    android:fontFamily="@font/custom_font"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    android:layout_marginBottom="5dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:padding="3dp"
                            android:id="@+id/logout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:elevation="12dp"
                            android:focusable="true"
                            android:layout_weight="1"
                            app:cardCornerRadius="8dp">

                            <LinearLayout
                                android:background="@color/white"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="90dp">

                                <ImageView
                                    android:padding="10dp"
                                    android:layout_gravity="center"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:src="@drawable/logout" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Logout"
                                    android:fontFamily="@font/custom_font"
                                    android:textAllCaps="false"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </RelativeLayout>
    

</RelativeLayout>
